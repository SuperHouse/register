# Mouser Order History API key - a SEPARATE key/application registration from
# MOUSER_SEARCH_API_KEY above, generated via My Mouser Account -> API management. Needed
# for Parts Orders order-status sync; leave blank to skip Mouser order syncing entirely.
MOUSER_ORDER_API_KEY = ""

# LCSC Order History (unofficial - via the separate lcsc-toolkit package; see its README's
# "Open questions" section for caveats: no OAuth/API-key flow, session lifetime
# unconfirmed). Capture a session with `python manage.py lcsc_capture_session` on a
# machine with a display (NOT this server), then copy the resulting file here. Leave blank
# to skip LCSC order syncing - it's manual-trigger-only via the Parts Orders "Refresh Now"
# button, not part of the scheduled refresh_parts_orders cron sync.
LCSC_SESSION_FILE = "/path/to/lcsc-session.json"

